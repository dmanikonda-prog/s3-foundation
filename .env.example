# ─────────────────────────────────────────────────
#  S3 Foundation — Environment Variables
#  Copy this file to .env for local development
#  Set these same variables in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────

# Admin panel password (change this before deploying!)
ADMIN_PASSWORD=admin123

# Local server port
PORT=3000

# ─────────────────────────────────────────────────
#  Supabase (required for admin edits on Vercel)
#  Get from: supabase.com → your project → Settings → API
# ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
